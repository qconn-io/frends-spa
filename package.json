{
  "name": "frends-spa",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "description": "Single-file Vue 3 + TypeScript SPA scaffold, served and deployed via Frends Processes.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && node scripts/check-singlefile.mjs",
    "preview": "vite preview",
    "deploy": "node --env-file-if-exists=.env scripts/deploy.mjs"
  },
  "dependencies": {
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vue-tsc": "^3.3.5"
  }
}
