# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# --- Local development (Vite dev server) ---
# Vite proxies every /api request to this Frends Agent host during `npm run dev`.
# In production the bundle is served from the Agent itself, so /api is same-origin
# and this value is unused. Only VITE_* variables are exposed to the browser bundle.
VITE_API_PROXY_TARGET=https://your-frends-agent.example.com

# --- Deployment (scripts/deploy.mjs — runs in Node, NOT bundled into the UI) ---
# URL of the "Deploy SPA Bundle" Process (HTTP POST, route template `spa-deploy`).
# See frends/deploy-spa-bundle/deploy-spa-bundle.spec.md.
FRENDS_DEPLOY_URL=https://maxsolutions-dev-agent.frendsapp.com/spa-deploy
# Deployment credential sent as the `x-api-key` header (Frends API Management key).
# Treat as a secret. Fill this in your local .env; never commit the real value.
FRENDS_DEPLOY_KEY=
# REQUIRED: the UI slug this repo deploys to. Sent as the `?slug=` query parameter and
# used to address the UI on serve (`GET /api/ui/<slug>`). Must match `^[a-z0-9-]+$`
# (lowercase alphanumeric and hyphen). Override per-run with `--slug <slug>`.
FRENDS_DEPLOY_SLUG=

# --- Serving (the "Serve SPA Shell" Process — used for smoke-testing the served bundle) ---
# GET endpoint (route template `ui/{slug}`) that serves a UI's current bundle. It is public
# (the API Management policy allows public access), so no API key is required. The slug is a
# required path segment — smoke-test the slug you deployed, e.g. .../ui/intake-form.
FRENDS_SERVE_URL=https://maxsolutions-dev-agent.frendsapp.com/ui
